{% extends "layout.html.j2" %}
{% block title %}Edit {{ name }} - nb-email-templating{% endblock %}
{% block content %}
<h1>Edit <code>{{ name }}</code></h1>
<p><a href="/templates">&larr; Back to templates</a></p>
<div id="editor-wrap" class="split">
  <section class="panel">
    {% if event_type %}
    <label for="subject-editor">Subject line ({{ event_type }})</label>
    <input id="subject-editor" class="subject-field" type="text" value="{{ subject or '' }}">
    <div class="recipients-section">
      <h3>Recipients</h3>
      <label for="recipients-to">To</label>
      <input id="recipients-to" class="recipients-field" type="text" value="{{ (recipients.get('to') or []) | join(', ') }}" placeholder="alice@example.com, bob@example.com">
      <label for="recipients-cc">CC</label>
      <input id="recipients-cc" class="recipients-field" type="text" value="{{ (recipients.get('cc') or []) | join(', ') }}" placeholder="team@example.com">
      <label for="recipients-bcc">BCC</label>
      <input id="recipients-bcc" class="recipients-field" type="text" value="{{ (recipients.get('bcc') or []) | join(', ') }}" placeholder="audit@example.com">
    </div>
    {% else %}
    <p class="panel-note">This file is not mapped to an event type, so there is no editable subject line.</p>
    {% endif %}
    <textarea id="editor" class="editor-area" rows="30">{{ content }}</textarea>
    <div style="margin-top:10px;">
      <button id="btn-save">Save</button>
      <button id="btn-preview">Preview</button>
      {% if event_type %}
      <button id="btn-apply-recipients">Apply recipients to all templates</button>
      {% endif %}
      <span id="status" style="margin-left:12px;"></span>
    </div>
  </section>
  <section class="panel">
    <h3>Preview</h3>
    <p id="preview-subject" class="panel-note"></p>
    <iframe id="preview-frame" style="width:100%; height:500px; border:0; border-radius:10px;"></iframe>
  </section>
</div>

<script>
(function() {
  var name = {{ name | tojson }};
  var editor = document.getElementById('editor');
  var subjectEditor = document.getElementById('subject-editor');
  var status = document.getElementById('status');
  var previewFrame = document.getElementById('preview-frame');
  var previewSubject = document.getElementById('preview-subject');
  var recipientsTo = document.getElementById('recipients-to');
  var recipientsCc = document.getElementById('recipients-cc');
  var recipientsBcc = document.getElementById('recipients-bcc');

  function getToken() {
    var m = location.search.match(/[?&]token=([^&]+)/);
    return m ? m[1] : '';
  }
  function apiUrl(path) {
    var t = getToken();
    return path + (t ? '?token=' + encodeURIComponent(t) : '');
  }
  function parseRecipientsValue(value) {
    if (!value) return [];
    return value.split(',').map(function(part) { return part.trim(); }).filter(function(part) { return part.length > 0; });
  }
  function getRecipientsPayload() {
    if (!recipientsTo && !recipientsCc && !recipientsBcc) {
      return null;
    }
    return {
      to: parseRecipientsValue(recipientsTo ? recipientsTo.value : ''),
      cc: parseRecipientsValue(recipientsCc ? recipientsCc.value : ''),
      bcc: parseRecipientsValue(recipientsBcc ? recipientsBcc.value : '')
    };
  }

  document.getElementById('btn-save').addEventListener('click', function() {
    status.textContent = 'Saving…';
    fetch(apiUrl('/api/templates/' + encodeURIComponent(name)), {
      method: 'PUT',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({
        content: editor.value,
        subject: subjectEditor ? subjectEditor.value : null,
        recipients: getRecipientsPayload()
      })
    }).then(function(r) { return r.json().then(function(d) { return {ok: r.ok, data: d}; }); })
      .then(function(res) {
        status.textContent = res.ok ? 'Saved.' : ('Error: ' + (res.data.detail || 'unknown'));
        status.className = res.ok ? 'status-ok' : 'status-error';
      })
      .catch(function(e) { status.textContent = 'Error: ' + e; status.className = 'status-error'; });
  });

  var applyRecipientsButton = document.getElementById('btn-apply-recipients');
  if (applyRecipientsButton) {
    applyRecipientsButton.addEventListener('click', function() {
      status.textContent = 'Applying recipients to all templates…';
      fetch(apiUrl('/api/templates/' + encodeURIComponent(name) + '/apply-recipients'), {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({recipients: getRecipientsPayload()})
      }).then(function(r) { return r.json().then(function(d) { return {ok: r.ok, data: d}; }); })
        .then(function(res) {
          if (res.ok) {
            status.textContent = 'Recipients applied to: ' + (res.data.applied_to || []).join(', ');
            status.className = 'status-ok';
          } else {
            status.textContent = 'Error: ' + (res.data.detail || 'unknown');
            status.className = 'status-error';
          }
        })
        .catch(function(e) { status.textContent = 'Error: ' + e; status.className = 'status-error'; });
    });
  }

  function buildSamplePayload(templateName) {
    var base = templateName.replace('.html.j2', '');
    var isIncident = base.indexOf('incident') !== -1;
    var isCleared = base.indexOf('cleared') !== -1;
    if (isIncident) {
      return {"data": {"type": "incident", "id": "preview-1", "attributes": {
        "event": isCleared ? "INCIDENT_CLEARED" : "INCIDENT_OPEN",
        "incident_id": 42,
        "agent": "demo-agent-01",
        "agent_description": "HQ Office Agent",
        "target": "8.8.8.8",
        "target_id": 101,
        "message": "High packet loss detected on ping to 8.8.8.8",
        "url": "https://app.netbeez.net/incidents/42",
        "incident_ts": Date.now()
      }}};
    }
    return {"data": {"type": "alert", "id": "preview-1", "attributes": {
      "event_type": isCleared ? "ALERT_CLEARED" : "ALERT_OPEN",
      "severity": 3,
      "severity_name": "Warning",
      "agent": "demo-agent-01",
      "agent_description": "HQ Office Agent",
      "target": "8.8.8.8",
      "destination": "dns.google",
      "test_type": "ping",
      "message": "Packet loss exceeded threshold on ping to 8.8.8.8",
      "alert_ts": Date.now()
    }}};
  }

  document.getElementById('btn-preview').addEventListener('click', function() {
    status.textContent = 'Rendering…';
    var samplePayload = buildSamplePayload(name);
    fetch(apiUrl('/api/templates/' + encodeURIComponent(name) + '/preview'), {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({payload: samplePayload})
    }).then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.html) {
          previewFrame.srcdoc = d.html;
          previewSubject.textContent = d.subject ? ('Subject: ' + d.subject) : '';
          status.textContent = d.error ? 'Preview (with warning): ' + d.error : 'Preview rendered.';
          status.className = d.error ? 'status-warn' : 'status-ok';
        } else {
          previewSubject.textContent = '';
          status.textContent = 'Preview error: ' + (d.error || d.detail || 'empty');
          status.className = 'status-error';
        }
      })
      .catch(function(e) { status.textContent = 'Error: ' + e; status.className = 'status-error'; });
  });

  editor.addEventListener('keydown', function(e) {
    if ((e.ctrlKey || e.metaKey) && e.key === 's') {
      e.preventDefault();
      document.getElementById('btn-save').click();
    }
  });
})();
</script>
{% endblock %}
