{% extends "layout.html.j2" %}
{% block title %}Overview - nb-email-templating{% endblock %}
{% block content %}
<h1>Overview</h1>
<section class="panel">
  <h2>Beezkeeper webhook</h2>
  <p class="panel-lead">Configure this URL in NetBeez Beezkeeper under <strong>Settings → Notification Integrations → Webhooks</strong>. Use the same URL for both <strong>alert</strong> (<code>Integrations::JsonApiAlertSerializer</code>) and <strong>incident</strong> (<code>Integrations::JsonApiIncidentSerializer</code>) webhooks.</p>
  <label class="webhook-url-label" for="beezkeeper-webhook-url">Webhook URL (POST)</label>
  <input id="beezkeeper-webhook-url" class="webhook-url-input" type="text" readonly value="{{ beezkeeper_webhook_url }}">
  {% if not config.auth.webhook_token %}
  <p class="panel-note">Set <code>auth.webhook_token</code> (or <code>NB_EMAIL_WEBHOOK_TOKEN</code>) so the URL includes a valid token.</p>
  {% endif %}
</section>
<section class="panel">
  <h2>Templates</h2>
  <ul class="template-list">
    {% for name, entry in (templates_config or {}).items() %}
    <li class="template-list-item">
      <div>
        <strong>{{ name }}</strong>: {{ entry.get('file', '') }}
      </div>
      <label class="toggle-switch" title="Enable or disable {{ name }}">
        <input
          type="checkbox"
          class="template-active-toggle"
          data-event-type="{{ name }}"
          {% if entry.get('active', true) %}checked{% endif %}
        >
        <span class="toggle-slider"></span>
      </label>
    </li>
    {% endfor %}
  </ul>
</section>
<section class="panel">
  <h2>Recent events</h2>
  <table>
    <thead><tr><th>ID</th><th>Event ID</th><th>Type</th><th>Status</th><th>Created</th></tr></thead>
    <tbody>
    {% for ev in events %}
    <tr>
      <td>{{ ev.id }}</td>
      <td>{{ ev.event_id[:20] }}...</td>
      <td>{{ ev.event_type }}</td>
      <td>{{ ev.status }}</td>
      <td>{{ ev.created_at }}</td>
    </tr>
    {% endfor %}
    </tbody>
  </table>
</section>
<script>
(function() {
  function getToken() {
    var m = location.search.match(/[?&]token=([^&]+)/);
    return m ? m[1] : '';
  }
  function apiUrl(path) {
    var t = getToken();
    return path + (t ? '?token=' + encodeURIComponent(t) : '');
  }
  document.querySelectorAll('.template-active-toggle').forEach(function(toggle) {
    toggle.addEventListener('change', function() {
      var requested = !!toggle.checked;
      var eventType = toggle.getAttribute('data-event-type');
      fetch(apiUrl('/api/templates/' + encodeURIComponent(eventType) + '/toggle-active'), {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({active: requested})
      }).then(function(r) { return r.json().then(function(d) { return {ok: r.ok, data: d}; }); })
        .then(function(res) {
          if (!res.ok) {
            toggle.checked = !requested;
            alert('Failed to update template state: ' + (res.data.detail || 'unknown'));
          }
        })
        .catch(function() {
          toggle.checked = !requested;
          alert('Failed to update template state due to a network error.');
        });
    });
  });
})();
</script>
{% endblock %}
