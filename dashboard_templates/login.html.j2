<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Login - NetBeez Email Dashboard</title>
  <link rel="stylesheet" href="/static/style.css">
</head>
<body class="login-page">
  <main class="login-main">
    <section class="login-card">
      <h1>NetBeez Email Dashboard</h1>
      <p class="login-subtitle">Enter password to access template and event operations.</p>
      {% if error %}
      <p class="login-error">Invalid password. Please try again.</p>
      {% endif %}
      <form method="post" action="/login" class="login-form">
        <label for="password">Password</label>
        <input id="password" name="password" type="password" required autofocus>
        <button type="submit">Sign in</button>
      </form>
    </section>
  </main>
</body>
</html>
