{% extends "_base.html.j2" %}
{% block title %}[NB] Agent Incident Cleared{% endblock %}
{% block content %}
<style>
  .badge { display: inline-block; padding: 4px 10px; border-radius: 6px; font-size: 12px; font-weight: 600; }
  .badge-success { background-color: #d4edda; color: #155724; }
  .detail-table { width: 100%; border-collapse: collapse; }
  .detail-table td { padding: 12px 0; border-bottom: 1px solid #e9ecef; vertical-align: top; }
  .detail-table tr:last-child td { border-bottom: none; }
  .detail-label { font-weight: 500; color: #6c757d; font-size: 14px; width: 40%; }
  .detail-value { color: #1a1a2e; text-align: right; }
  .message-box { background: #e8f5e9; border-left: 4px solid #2e7d32; padding: 14px 16px; margin-bottom: 20px; border-radius: 0 8px 8px 0; }
  .message-box p { margin: 0; font-weight: 500; color: #1a1a2e; }
  .btn { display: inline-block; padding: 12px 20px; background: linear-gradient(135deg, #16213e 0%, #1a1a2e 100%); color: #fff !important; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 14px; margin-top: 8px; }
</style>
<span class="badge badge-success">Cleared</span>
<h2>Incident resolved</h2>
<div class="message-box">
  <p>{{ attributes.message or 'Incident has been cleared.' }}</p>
</div>
<table class="detail-table">
  {% if attributes.agent %}<tr><td class="detail-label">Agent</td><td class="detail-value">{{ attributes.agent }}</td></tr>{% endif %}
  {% if attributes.test_type %}<tr><td class="detail-label">Test type</td><td class="detail-value">{{ attributes.test_type }}</td></tr>{% endif %}
  {% if attributes.target %}<tr><td class="detail-label">Target</td><td class="detail-value">{{ attributes.target }}</td></tr>{% endif %}
  {% if attributes.incident_ts %}<tr><td class="detail-label">Original start</td><td class="detail-value">{{ attributes.incident_ts | format_ts }}</td></tr>{% endif %}
</table>
{% if attributes.tests is defined and attributes.tests is iterable and attributes.tests is not string %}
<table class="detail-table" style="margin-top:16px;">
  <tr><td colspan="2" class="detail-label" style="border-bottom:none;padding-bottom:4px;">Tests in this incident</td></tr>
  {% for t in attributes.tests %}
  <tr>
    <td class="detail-label">{% if t is mapping %}{{ t.name or t.target or t.destination or ('Test ' ~ loop.index) }}{% else %}{{ t }}{% endif %}</td>
    <td class="detail-value">{% if t is mapping %}{{ t.status or t.state or t.message or '—' }}{% else %}—{% endif %}</td>
  </tr>
  {% endfor %}
</table>
{% endif %}
{% set incident_link = attributes.url | default('', true) | rewrite_url_origin %}
{% if incident_link %}<a href="{{ incident_link }}" class="btn">View incident in NetBeez</a>{% endif %}
{% endblock %}
