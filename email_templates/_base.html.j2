<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}NetBeez Notification{% endblock %}</title>
  <!--[if mso]>
  <noscript>
    <xml>
      <o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings>
    </xml>
  </noscript>
  <![endif]-->
  <style>
    body {
      margin: 0;
      padding: 0;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      font-size: 16px;
      line-height: 1.6;
      color: #1a1a2e;
      background-color: #f0f2f5;
      -webkit-font-smoothing: antialiased;
    }
    .wrapper {
      width: 100%;
      background-color: #f0f2f5;
      padding: 32px 16px;
    }
    .container {
      max-width: 560px;
      margin: 0 auto;
      background-color: #ffffff;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
    }
    .header {
      background: linear-gradient(135deg, #16213e 0%, #1a1a2e 100%);
      color: #ffffff;
      padding: 24px 28px;
      text-align: left;
    }
    .header-brand {
      font-size: 20px;
      font-weight: 700;
      letter-spacing: -0.02em;
    }
    .header-tagline {
      font-size: 12px;
      opacity: 0.85;
      margin-top: 4px;
    }
    .content {
      padding: 28px;
    }
    .content h2 {
      margin: 0 0 20px 0;
      font-size: 20px;
      font-weight: 600;
      color: #1a1a2e;
      letter-spacing: -0.01em;
    }
    .footer {
      background-color: #f8f9fa;
      padding: 20px 28px;
      font-size: 12px;
      color: #6c757d;
      border-top: 1px solid #e9ecef;
    }
    .footer p { margin: 0; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="container">
      <div class="header">
        <div class="header-brand">NetBeez</div>
        <div class="header-tagline">Network monitoring &amp; alerting</div>
      </div>
      <div class="content">
        {% block content %}{% endblock %}
      </div>
      <div class="footer">
        <p>This is an automated notification from NetBeez. You received this because you are subscribed to alert or incident notifications.</p>
      </div>
    </div>
  </div>
</body>
</html>
