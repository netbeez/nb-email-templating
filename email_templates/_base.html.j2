<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}NetBeez Notification{% endblock %}</title>
  <!--[if mso]>
  <noscript>
    <xml>
      <o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings>
    </xml>
  </noscript>
  <![endif]-->
  <style>
    body {
      margin: 0;
      padding: 0;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      font-size: 16px;
      line-height: 1.6;
      color: #1a1a2e;
      background-color: #f0f2f5;
      -webkit-font-smoothing: antialiased;
    }
    table {
      border-collapse: collapse;
    }
    .wrapper {
      width: 100%;
      background-color: #f0f2f5;
    }
    .container {
      width: 560px;
      background-color: #ffffff;
    }
    .header {
      background-color: #16213e;
      color: #ffffff;
      padding: 24px 28px;
      text-align: left;
    }
    .header-brand {
      font-size: 20px;
      font-weight: 700;
      letter-spacing: -0.02em;
    }
    .header-tagline {
      font-size: 12px;
      opacity: 0.85;
      margin-top: 4px;
    }
    .content {
      padding: 28px;
    }
    .content h2 {
      margin: 0 0 20px 0;
      font-size: 20px;
      font-weight: 600;
      color: #1a1a2e;
      letter-spacing: -0.01em;
    }
    .footer {
      background-color: #f8f9fa;
      padding: 20px 28px;
      font-size: 12px;
      color: #6c757d;
      border-top: 1px solid #e9ecef;
    }
    .footer p { margin: 0; }
  </style>
</head>
<body>
  <table role="presentation" class="wrapper" width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td align="center" style="padding:32px 16px;">
        <table role="presentation" class="container" width="560" cellpadding="0" cellspacing="0">
          <tr>
            <td class="header">
              <div class="header-brand">NetBeez</div>
              <div class="header-tagline">Network monitoring &amp; alerting</div>
            </td>
          </tr>
          <tr>
            <td class="content">
              {% block content %}{% endblock %}
            </td>
          </tr>
          <tr>
            <td class="footer">
              <p>This is an automated notification from NetBeez. You received this because you are subscribed to alert or incident notifications.</p>
              {% if netbeez_dashboard_url %}
              <p style="margin-top:12px;">View the Dashboard at <a href="{{ netbeez_dashboard_url }}">{{ netbeez_dashboard_url }}</a></p>
              {% endif %}
              {% if staff_sop_url %}
              <p style="margin-top:12px;"><a href="{{ staff_sop_url }}">Staff troubleshooting (SOP)</a></p>
              {% endif %}
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
